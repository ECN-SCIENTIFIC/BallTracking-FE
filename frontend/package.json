{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"mock:backend": "node mock-backend.cjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"start": "node server.cjs",
		"pkg": "npm run build && pkg server.cjs --target node18-win-x64 --output f80-meter.exe",
		"pkg:all": "npm run build && pkg server.cjs --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output f80-meter"
	},
	"bin": "server.cjs",
	"pkg": {
		"assets": [
			"build/**/*"
		],
		"outputPath": "dist"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"eslint": "^9.18.0",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"pkg": "^5.8.1",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.6"
	},
	"dependencies": {
		"apexcharts": "^4.7.0",
		"svelte-apexcharts": "^1.0.2"
	}
}
